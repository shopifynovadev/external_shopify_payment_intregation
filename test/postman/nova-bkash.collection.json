{
  "info": {
    "name": "Nova bKash Backend Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01. Health Check",
      "item": [
        {
          "name": "1.1 Health - DB up",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/health", "host": ["{{base_url}}"], "path": ["api", "health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('status ok or degraded', () => pm.expect(json.status).to.be.oneOf(['ok', 'degraded']));",
                  "pm.test('db connected', () => pm.expect(json.db).to.equal('connected'));",
                  "pm.test('has queues', () => pm.expect(json.queues).to.exist);",
                  "pm.test('has timestamp', () => pm.expect(json.timestamp).to.be.a('string'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02. Payment Initiate",
      "item": [
        {
          "name": "2.1 Initiate - Happy path",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopDomain\": \"{{shop_domain}}\",\n  \"cartId\": \"gid://shopify/Cart/test-cart-001\",\n  \"shippingHandle\": \"{{shipping_handle}}\",\n  \"customerInfo\": {\n    \"name\": \"Test User\",\n    \"phone\": \"01712345678\",\n    \"email\": \"test@example.com\",\n    \"address\": {\n      \"division\": \"Dhaka\",\n      \"district\": \"Dhaka\",\n      \"thana\": \"Gulshan\",\n      \"street\": \"House 1, Road 2, Gulshan-1\"\n    }\n  },\n  \"lineItems\": [\n    { \"variantId\": \"{{test_variant_id}}\", \"quantity\": 1 }\n  ],\n  \"subtotal\": {{test_subtotal}}\n}"
            },
            "url": { "raw": "{{base_url}}/api/payment/initiate", "host": ["{{base_url}}"], "path": ["api", "payment", "initiate"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('has paymentId', () => pm.expect(json.data.paymentId).to.exist);",
                  "pm.test('has redirectUrl', () => pm.expect(json.data.redirectUrl).to.be.a('string'));",
                  "pm.environment.set('payment_id', json.data.paymentId);",
                  "// Extract bkash paymentID from the redirectUrl query param",
                  "const url = new URL(json.data.redirectUrl);",
                  "const bkashPaymentId = url.searchParams.get('paymentID');",
                  "pm.environment.set('bkash_payment_id', bkashPaymentId);",
                  "console.log('payment_id:', json.data.paymentId);",
                  "console.log('bkash_payment_id:', bkashPaymentId);",
                  "console.log('bKash URL (open in browser to pay):', json.data.redirectUrl);"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Initiate - Idempotency (same cartId within 5 min)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopDomain\": \"{{shop_domain}}\",\n  \"cartId\": \"gid://shopify/Cart/test-cart-001\",\n  \"shippingHandle\": \"{{shipping_handle}}\",\n  \"customerInfo\": {\n    \"name\": \"Test User\",\n    \"phone\": \"01712345678\",\n    \"email\": \"test@example.com\",\n    \"address\": {\n      \"division\": \"Dhaka\",\n      \"district\": \"Dhaka\",\n      \"thana\": \"Gulshan\",\n      \"street\": \"House 1, Road 2, Gulshan-1\"\n    }\n  },\n  \"lineItems\": [\n    { \"variantId\": \"{{test_variant_id}}\", \"quantity\": 1 }\n  ],\n  \"subtotal\": {{test_subtotal}}\n}"
            },
            "url": { "raw": "{{base_url}}/api/payment/initiate", "host": ["{{base_url}}"], "path": ["api", "payment", "initiate"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.be.true);",
                  "const originalPaymentId = pm.environment.get('payment_id');",
                  "pm.test('same paymentId returned (idempotent)', () => {",
                  "  pm.expect(json.data.paymentId).to.equal(originalPaymentId);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.3 Initiate - Invalid discount code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopDomain\": \"{{shop_domain}}\",\n  \"cartId\": \"gid://shopify/Cart/test-cart-discount\",\n  \"shippingHandle\": \"{{shipping_handle}}\",\n  \"discountCode\": \"INVALID_CODE_XYZ\",\n  \"customerInfo\": {\n    \"name\": \"Test User\",\n    \"phone\": \"01712345678\",\n    \"email\": \"test@example.com\",\n    \"address\": {\n      \"division\": \"Dhaka\",\n      \"district\": \"Dhaka\",\n      \"thana\": \"Gulshan\",\n      \"street\": \"House 1, Road 2\"\n    }\n  },\n  \"lineItems\": [\n    { \"variantId\": \"{{test_variant_id}}\", \"quantity\": 1 }\n  ],\n  \"subtotal\": {{test_subtotal}}\n}"
            },
            "url": { "raw": "{{base_url}}/api/payment/initiate", "host": ["{{base_url}}"], "path": ["api", "payment", "initiate"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "const json = pm.response.json();",
                  "pm.test('success false', () => pm.expect(json.success).to.be.false);",
                  "pm.test('INVALID_DISCOUNT code', () => pm.expect(json.code).to.equal('INVALID_DISCOUNT'));"
                ]
              }
            }
          ]
        },
        {
          "name": "2.4 Initiate - Missing required fields",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopDomain\": \"{{shop_domain}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/payment/initiate", "host": ["{{base_url}}"], "path": ["api", "payment", "initiate"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('success false', () => pm.expect(json.success).to.be.false);",
                  "pm.test('has error message', () => pm.expect(json.error).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "2.5 Initiate - Shop not configured (wrong shopDomain)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopDomain\": \"nonexistent-shop.myshopify.com\",\n  \"cartId\": \"gid://shopify/Cart/test-cart-999\",\n  \"shippingHandle\": \"some-handle\",\n  \"customerInfo\": {\n    \"name\": \"Test User\",\n    \"phone\": \"01712345678\",\n    \"email\": \"test@example.com\",\n    \"address\": {\n      \"division\": \"Dhaka\",\n      \"district\": \"Dhaka\",\n      \"thana\": \"Gulshan\",\n      \"street\": \"House 1\"\n    }\n  },\n  \"lineItems\": [{ \"variantId\": \"gid://shopify/ProductVariant/1\", \"quantity\": 1 }],\n  \"subtotal\": 100\n}"
            },
            "url": { "raw": "{{base_url}}/api/payment/initiate", "host": ["{{base_url}}"], "path": ["api", "payment", "initiate"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "const json = pm.response.json();",
                  "pm.test('NOT_CONFIGURED code', () => pm.expect(json.code).to.equal('NOT_CONFIGURED'));"
                ]
              }
            }
          ]
        },
        {
          "name": "2.6 Initiate - Invalid JSON body",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "this is not json" },
            "url": { "raw": "{{base_url}}/api/payment/initiate", "host": ["{{base_url}}"], "path": ["api", "payment", "initiate"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('Invalid JSON error', () => pm.expect(json.error).to.include('JSON'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03. Payment Callback (Cancel + Failure)",
      "description": "Run 2.1 first to get bkash_payment_id. The success/execute path requires completing payment in the bKash sandbox browser — bKash will redirect to callback automatically. Disable 'Follow Redirects' in Postman Settings to see the 302 Location header.",
      "item": [
        {
          "name": "3.1 Callback - status=cancel → FAILED",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payment/callback?paymentID={{bkash_payment_id}}&status=cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "payment", "callback"],
              "query": [
                { "key": "paymentID", "value": "{{bkash_payment_id}}" },
                { "key": "status", "value": "cancel" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Postman follows redirects by default — check final URL contains payment_status=failed",
                  "// OR disable 'Follow Redirects' to check 302 Location header directly",
                  "const finalUrl = pm.response.url;",
                  "pm.test('Redirected to cart with failed status', () => {",
                  "  pm.expect(finalUrl).to.include('payment_status=failed');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Callback - status=failure → FAILED",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payment/callback?paymentID={{bkash_payment_id_2}}&status=failure",
              "host": ["{{base_url}}"],
              "path": ["api", "payment", "callback"],
              "query": [
                { "key": "paymentID", "value": "{{bkash_payment_id_2}}" },
                { "key": "status", "value": "failure" }
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Run 2.1 again with a different cartId first to get a fresh bkash_payment_id_2"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const finalUrl = pm.response.url;",
                  "pm.test('Redirected to cart with failed status', () => {",
                  "  pm.expect(finalUrl).to.include('payment_status=failed');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.3 Callback - missing paymentID → error redirect",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payment/callback?status=success",
              "host": ["{{base_url}}"],
              "path": ["api", "payment", "callback"],
              "query": [{ "key": "status", "value": "success" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const finalUrl = pm.response.url;",
                  "pm.test('Redirected with missing_payment_id error', () => {",
                  "  pm.expect(finalUrl).to.include('payment_error=missing_payment_id');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3.4 Callback - unknown paymentID → not_found redirect",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payment/callback?paymentID=nonexistent-bkash-id-xyz&status=success",
              "host": ["{{base_url}}"],
              "path": ["api", "payment", "callback"],
              "query": [
                { "key": "paymentID", "value": "nonexistent-bkash-id-xyz" },
                { "key": "status", "value": "success" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const finalUrl = pm.response.url;",
                  "pm.test('Redirected with not_found error', () => {",
                  "  pm.expect(finalUrl).to.include('payment_error=not_found');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04. Payment Status",
      "item": [
        {
          "name": "4.1 Status - After cancel (FAILED)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payment/status/{{payment_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "payment", "status", "{{payment_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('payment status is FAILED', () => pm.expect(json.data.status).to.equal('FAILED'));",
                  "pm.test('no shopify order number (payment failed)', () => {",
                  "  pm.expect(json.data.shopifyOrderNumber).to.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4.2 Status - COMPLETED (run after successful bKash sandbox payment)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payment/status/{{completed_payment_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "payment", "status", "{{completed_payment_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('payment COMPLETED', () => pm.expect(json.data.status).to.equal('COMPLETED'));",
                  "pm.test('has shopify order number', () => pm.expect(json.data.shopifyOrderNumber).to.be.a('string'));",
                  "pm.test('has bkash transaction ID', () => pm.expect(json.data.bkashTransactionId).to.be.a('string'));",
                  "pm.environment.set('completed_bkash_trx_id', json.data.bkashTransactionId);"
                ]
              }
            }
          ]
        },
        {
          "name": "4.3 Status - Non-existent payment ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payment/status/nonexistent-id-xyz-000",
              "host": ["{{base_url}}"],
              "path": ["api", "payment", "status", "nonexistent-id-xyz-000"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('data is null for unknown id', () => pm.expect(json.data).to.be.null);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05. Discount Validate",
