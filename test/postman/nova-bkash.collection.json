    {
      "name": "06. Cron Jobs",
      "item": [
        {
          "name": "6.1 Cleanup - No auth → 401",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/cron/cleanup", "host": ["{{base_url}}"], "path": ["api", "cron", "cleanup"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "const json = pm.response.json();",
                  "pm.test('Unauthorized error', () => pm.expect(json.success).to.be.false);"
                ]
              }
            }
          ]
        },
        {
          "name": "6.2 Cleanup - Wrong secret → 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer wrong-secret-xyz" }],
            "url": { "raw": "{{base_url}}/api/cron/cleanup", "host": ["{{base_url}}"], "path": ["api", "cron", "cleanup"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "6.3 Cleanup - Valid auth → 200",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{cron_secret}}" }],
            "url": { "raw": "{{base_url}}/api/cron/cleanup", "host": ["{{base_url}}"], "path": ["api", "cron", "cleanup"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
