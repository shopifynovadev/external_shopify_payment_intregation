                  "pm.test('has abandoned count', () => pm.expect(json.data.abandoned).to.be.a('number'));",
                  "console.log('Abandoned payments cleaned up:', json.data.abandoned);"
                ]
              }
            }
          ]
        },
        {
          "name": "6.4 Billing - No auth → 401",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/cron/billing", "host": ["{{base_url}}"], "path": ["api", "cron", "billing"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "6.5 Billing - Valid auth → 200",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{cron_secret}}" }],
            "url": { "raw": "{{base_url}}/api/cron/billing", "host": ["{{base_url}}"], "path": ["api", "cron", "billing"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('has summary counts', () => {",
                  "  pm.expect(json.data.total).to.be.a('number');",
                  "  pm.expect(json.data.created).to.be.a('number');",
                  "  pm.expect(json.data.skipped).to.be.a('number');",
                  "});",
                  "console.log('Billing result:', JSON.stringify(json.data));"
                ]
              }
            }
          ]
        },
        {
          "name": "6.6 Billing - Idempotency (run twice same day)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{cron_secret}}" }],
            "url": { "raw": "{{base_url}}/api/cron/billing", "host": ["{{base_url}}"], "path": ["api", "cron", "billing"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('created = 0 (idempotent — no duplicate invoices)', () => {",
                  "  pm.expect(json.data.created).to.equal(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "6.7 Reconcile - Valid auth",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{cron_secret}}" }],
            "url": { "raw": "{{base_url}}/api/cron/reconcile", "host": ["{{base_url}}"], "path": ["api", "cron", "reconcile"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.be.true);",
                  "console.log('Reconcile result:', JSON.stringify(json.data));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "07. Webhooks - Refund",
      "description": "Pre-request script auto-computes HMAC using shopify_api_secret env var. Make sure to set shopify_api_secret in the environment.",
      "item": [
        {
          "name": "7.1 Refund webhook - Valid HMAC, order not in DB (skip)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Shopify-Topic", "value": "orders/refunded" },
              { "key": "X-Shopify-Shop-Domain", "value": "{{shop_domain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 999999999,\n  \"admin_graphql_api_id\": \"gid://shopify/Order/999999999\",\n  \"refunds\": [\n    {\n      \"id\": 111111111,\n      \"admin_graphql_api_id\": \"gid://shopify/Refund/111111111\",\n      \"note\": \"Test refund\",\n      \"transactions\": [\n        { \"id\": 1, \"amount\": \"100.00\" }\n      ]\n    }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/webhooks/orders/refunded", "host": ["{{base_url}}"], "path": ["webhooks", "orders", "refunded"] }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const secret = pm.environment.get('shopify_api_secret');",
                  "const body = pm.request.body.raw;",
                  "const hmac = CryptoJS.HmacSHA256(body, secret);",
                  "const hmacBase64 = CryptoJS.enc.Base64.stringify(hmac);",
                  "pm.request.headers.upsert({ key: 'X-Shopify-Hmac-SHA256', value: hmacBase64 });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Order not in DB → webhook returns 200 with skip (Shopify stops retrying)",
                  "pm.test('Status 200 (idempotent skip)', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "7.2 Refund webhook - Valid HMAC, real order (triggers bKash refund)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Shopify-Topic", "value": "orders/refunded" },
              { "key": "X-Shopify-Shop-Domain", "value": "{{shop_domain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"admin_graphql_api_id\": \"{{completed_shopify_order_gid}}\",\n  \"refunds\": [\n    {\n      \"id\": 222222222,\n      \"admin_graphql_api_id\": \"gid://shopify/Refund/222222222\",\n      \"note\": \"Customer requested refund\",\n      \"transactions\": [\n        { \"id\": 2, \"amount\": \"{{test_subtotal}}\" }\n      ]\n    }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/webhooks/orders/refunded", "host": ["{{base_url}}"], "path": ["webhooks", "orders", "refunded"] }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const secret = pm.environment.get('shopify_api_secret');",
                  "const body = pm.request.body.raw;",
                  "const hmac = CryptoJS.HmacSHA256(body, secret);",
                  "const hmacBase64 = CryptoJS.enc.Base64.stringify(hmac);",
                  "pm.request.headers.upsert({ key: 'X-Shopify-Hmac-SHA256', value: hmacBase64 });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 (queued)', () => pm.response.to.have.status(200));",
                  "// After ~5 seconds, check DB: Refund row should exist with status PENDING or COMPLETED"
                ]
              }
            }
          ]
        },
        {
          "name": "7.3 Refund webhook - Duplicate (idempotency)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Shopify-Topic", "value": "orders/refunded" },
              { "key": "X-Shopify-Shop-Domain", "value": "{{shop_domain}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"admin_graphql_api_id\": \"{{completed_shopify_order_gid}}\",\n  \"refunds\": [\n    {\n      \"id\": 222222222,\n      \"admin_graphql_api_id\": \"gid://shopify/Refund/222222222\",\n      \"note\": \"Customer requested refund\",\n      \"transactions\": [\n        { \"id\": 2, \"amount\": \"{{test_subtotal}}\" }\n      ]\n    }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/webhooks/orders/refunded", "host": ["{{base_url}}"], "path": ["webhooks", "orders", "refunded"] }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const secret = pm.environment.get('shopify_api_secret');",
                  "const body = pm.request.body.raw;",
                  "const hmac = CryptoJS.HmacSHA256(body, secret);",
                  "const hmacBase64 = CryptoJS.enc.Base64.stringify(hmac);",
                  "pm.request.headers.upsert({ key: 'X-Shopify-Hmac-SHA256', value: hmacBase64 });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Same shopifyRefundId → should return 200 without double-refunding",
                  "pm.test('Status 200 (idempotent)', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "7.4 Refund webhook - Invalid HMAC → 401/403",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Shopify-Topic", "value": "orders/refunded" },
              { "key": "X-Shopify-Shop-Domain", "value": "{{shop_domain}}" },
              { "key": "X-Shopify-Hmac-SHA256", "value": "invalidsignatureabc123" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"admin_graphql_api_id\": \"gid://shopify/Order/1\",\n  \"refunds\": []\n}"
            },
            "url": { "raw": "{{base_url}}/webhooks/orders/refunded", "host": ["{{base_url}}"], "path": ["webhooks", "orders", "refunded"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejected (401 or 403)', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "08. CORS / Security",
      "item": [
        {
          "name": "8.1 OPTIONS /api/payment/initiate → CORS headers present",
          "request": {
            "method": "OPTIONS",
            "header": [
              { "key": "Origin", "value": "https://{{shop_domain}}" },
              { "key": "Access-Control-Request-Method", "value": "POST" }
            ],
            "url": { "raw": "{{base_url}}/api/payment/initiate", "host": ["{{base_url}}"], "path": ["api", "payment", "initiate"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Has Access-Control-Allow-Origin', () => {",
                  "  pm.expect(pm.response.headers.get('Access-Control-Allow-Origin')).to.exist;",
                  "});",
                  "pm.test('Has Access-Control-Allow-Methods', () => {",
                  "  pm.expect(pm.response.headers.get('Access-Control-Allow-Methods')).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "8.2 GET /api/payment/status/:id → CORS headers present",
          "request": {
            "method": "GET",
            "header": [{ "key": "Origin", "value": "https://{{shop_domain}}" }],
            "url": {
              "raw": "{{base_url}}/api/payment/status/{{payment_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "payment", "status", "{{payment_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Has CORS header', () => {",
                  "  pm.expect(pm.response.headers.get('Access-Control-Allow-Origin')).to.exist;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "8.3 GET /api/storefront-config → returns token + appUrl",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Origin", "value": "https://{{shop_domain}}" },
              { "key": "x-shop-domain", "value": "{{shop_domain}}" }
            ],
            "url": { "raw": "{{base_url}}/api/storefront-config", "host": ["{{base_url}}"], "path": ["api", "storefront-config"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('has storefrontToken', () => pm.expect(json.data.storefrontToken).to.be.a('string'));",
                  "pm.test('has appUrl', () => pm.expect(json.data.appUrl).to.be.a('string'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "09. OTP Flow (Manual — App UI only)",
      "description": "OTP routes require authenticate.admin() (Shopify embedded app session). Cannot be called directly from Postman without a valid Shopify session cookie/token. Test these manually:\n\n1. Open your app in Shopify Admin → Settings page\n2. Click 'Update bKash Credentials'\n3. System sends OTP to merchant email\n4. VERIFY: OTP email arrives within 5 seconds\n5. Enter correct code → credentials saved, token cache invalidated\n6. VERIFY: GET /api/settings/bkash shows masked credentials\n7. Enter wrong code 3× → 'Too many attempts. Try again in 15 minutes.'\n8. Wait 2 min, enter expired OTP → 'OTP has expired'\n\nTo verify in DB (via psql or Prisma Studio):\n  SELECT * FROM otp_requests ORDER BY created_at DESC LIMIT 5;\n  SELECT bkash_app_key IS NOT NULL as configured FROM merchant_settings WHERE shop_domain = 'your-shop.myshopify.com';",
      "item": [
