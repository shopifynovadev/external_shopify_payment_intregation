{% comment %}
  Payment Options Block — Nova bKash
  Renders selectable payment plan options (Delivery Only / 25% / 50% / Full Pay)
  Each option can be individually enabled/disabled from the theme editor schema.
{% endcomment %}

{%- assign active_options = 0 -%}
{%- if block.settings.delivery_only_label != blank -%}{%- assign active_options = active_options | plus: 1 -%}{%- endif -%}
{%- if block.settings.percent_25_label != blank -%}{%- assign active_options = active_options | plus: 1 -%}{%- endif -%}
{%- if block.settings.percent_50_label != blank -%}{%- assign active_options = active_options | plus: 1 -%}{%- endif -%}
{%- if block.settings.full_pay_label != blank -%}{%- assign active_options = active_options | plus: 1 -%}{%- endif -%}

{%- if active_options == 0 -%}
  {% comment %} No options enabled — render nothing {% endcomment %}
{%- else -%}

<checkout-form-payment-options
  class="checkout-form_payment-options"
  data-block-id="{{ block.id }}"
  data-currency="{{ cart.currency.symbol }}"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.label != blank -%}
    <p class="checkout-form_payment-options__label">{{ block.settings.label }}</p>
  {%- endif -%}

  <div class="checkout-form_payment-options__grid" data-option-count="{{ active_options }}">

    {%- if block.settings.full_pay_label != blank -%}
      <label class="checkout-form_payment-option" data-type="full">
        <input
          class="checkout-form_payment-option__input"
          type="radio"
          name="nova_payment_plan"
          value="pay_100"
          data-multiplier="1"
          data-label="{{ block.settings.full_pay_label | escape }}"
          checked
        >
        <span class="checkout-form_payment-option__card">
          <span class="checkout-form_payment-option__radio-dot"></span>
          <span class="checkout-form_payment-option__icon">
            {%- render 'checkout-form_icon-wallet' -%}
          </span>
          <span class="checkout-form_payment-option__text">
            <span class="checkout-form_payment-option__title">{{ block.settings.full_pay_label }}</span>
            <span class="checkout-form_payment-option__amount" data-amount></span>
          </span>
        </span>
      </label>
    {%- endif -%}

    {%- if block.settings.percent_50_label != blank -%}
      <label class="checkout-form_payment-option" data-type="50">
        <input
          class="checkout-form_payment-option__input"
          type="radio"
          name="nova_payment_plan"
          value="pay_50"
          data-multiplier="0.50"
          data-label="{{ block.settings.percent_50_label | escape }}"
        >
        <span class="checkout-form_payment-option__card">
          <span class="checkout-form_payment-option__radio-dot"></span>
          <span class="checkout-form_payment-option__icon">
            {%- render 'checkout-form_icon-half' -%}
          </span>
          <span class="checkout-form_payment-option__text">
            <span class="checkout-form_payment-option__title">{{ block.settings.percent_50_label }}</span>
            <span class="checkout-form_payment-option__amount" data-amount></span>
          </span>
        </span>
      </label>
    {%- endif -%}

    {%- if block.settings.percent_25_label != blank -%}
      <label class="checkout-form_payment-option" data-type="25">
        <input
          class="checkout-form_payment-option__input"
          type="radio"
          name="nova_payment_plan"
          value="pay_25"
          data-multiplier="0.25"
          data-label="{{ block.settings.percent_25_label | escape }}"
        >
        <span class="checkout-form_payment-option__card">
          <span class="checkout-form_payment-option__radio-dot"></span>
          <span class="checkout-form_payment-option__icon">
            {%- render 'checkout-form_icon-partial' -%}
          </span>
          <span class="checkout-form_payment-option__text">
            <span class="checkout-form_payment-option__title">{{ block.settings.percent_25_label }}</span>
            <span class="checkout-form_payment-option__amount" data-amount></span>
          </span>
        </span>
      </label>
    {%- endif -%}

    {%- if block.settings.delivery_only_label != blank -%}
      <label class="checkout-form_payment-option" data-type="delivery">
        <input
          class="checkout-form_payment-option__input"
          type="radio"
          name="nova_payment_plan"
          value="pay_delivery"
          data-multiplier="0"
          data-label="{{ block.settings.delivery_only_label | escape }}"
        >
        <span class="checkout-form_payment-option__card">
          <span class="checkout-form_payment-option__radio-dot"></span>
          <span class="checkout-form_payment-option__icon">
            {%- render 'checkout-form_icon-delivery' -%}
          </span>
          <span class="checkout-form_payment-option__text">
            <span class="checkout-form_payment-option__title">{{ block.settings.delivery_only_label }}</span>
            <span class="checkout-form_payment-option__amount" data-amount></span>
          </span>
        </span>
      </label>
    {%- endif -%}

  </div>

  {%- comment %} Hidden inputs consumed by cart-block's payment initiation logic {%- endcomment %}
  <input type="hidden" id="checkout-form_selected-plan" name="checkout-form_selected-plan"   value="">
  <input type="hidden" id="checkout-form_selected-amount" name="checkout-form_selected-amount" value="">

</checkout-form-payment-options>

{%- endif -%}
