{% if cart.items != blank or request.design_mode %}
  {% render 'checkout-form', section_details: block %}
{% endif %}

{% schema %}
{
  "name": "Checkout Form",
  "target": "section",
  "templates": ["cart"],
  "settings": [
    {
      "type": "header",
      "content": "Content Layout"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "Text alignment",
      "default": "center"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<h2>Complete Your Order</h2>"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ]
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font size",
      "min": 12,
      "max": 80,
      "step": 1,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Securely checkout with your information and pay with bKash</p>"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "label": "Text Font size",
      "min": 12,
      "max": 80,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Customer Contact Layout",
      "info": "The contact method customers enter at checkout will receive order and shipping notifications"
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "Title",
      "default": "Contact Information"
    },
    {
      "type": "radio",
      "id": "contact_selection",
      "label": "Contact Method",
      "options": [
        {
          "value": "both",
          "label": "Phone number or email"
        },
        {
          "value": "email",
          "label": "Email (required)"
        },
        {
          "value": "phone_number",
          "label": "Phone number (required)"
        }
      ],
      "default": "both",
      "info": "An SMS App is required to send SMS updates"
    },
    {
      "type": "header",
      "content": "Customer Information Layout"
    },
    {
      "type": "text",
      "id": "customer_information_title",
      "label": "Title",
      "default": "Customer Information"
    },
    {
      "type": "radio",
      "id": "full_name",
      "label": "Full Name",
      "options": [
        {
          "value": "both",
          "label": "First Name and Last Name"
        },
        {
          "value": "first_name",
          "label": "Only First Name"
        }
      ],
      "default": "both"
    },
    {
      "type": "checkbox",
      "id": "show_postal_code",
      "label": "Show Postal Code",
      "default": true
    },
    {
      "type": "header",
      "content": "Customer Shipping Details Layout"
    },
    {
      "type": "text",
      "id": "customer_shipping_details_title",
      "label": "Title",
      "default": "Shipping Methods"
    },
    {
      "type": "checkbox",
      "id": "show_cart_discount",
      "label": "Show Cart Discount",
      "default": true
    },
    {
      "type": "header",
      "content": "Payment Methods",
      "info": "Remove option title to hide the option for payment"
    },
    {
      "type": "text",
      "id": "customer_payment_methods_title",
      "label": "Title",
      "default": "Payment Method"
    },
    {
      "type": "text",
      "id": "delivery_only_label",
      "label": "Delivery Label",
      "default": "Delivery Only",
      "info": "Customer pays the delivery charge now. Remaining balance on delivery (COD-style)."
    },
    {
      "type": "text",
      "id": "percent_25_label",
      "label": "25% Payment Label",
      "default": "25% Pay"
    },
    {
      "type": "text",
      "id": "percent_50_label",
      "label": "50% Payment Label",
      "default": "50% Pay"
    },
    {
      "type": "text",
      "id": "full_pay_label",
      "label": "Full Payment Label",
      "default": "Full Pay",
      "info": "Recommended. Always shown by default."
    }
  ]
}
{% endschema %}
